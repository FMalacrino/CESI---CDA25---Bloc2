<?xml version="1.0" encoding="utf-8" ?>
<ContentPage
    x:Class="Security.Mobile.Views.LoginView"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:material="clr-namespace:HorusStudio.Maui.MaterialDesignControls;assembly=HorusStudio.Maui.MaterialDesignControls"
    xmlns:viewmodels="clr-namespace:Security.Mobile.ViewModels">

    <ContentPage.BindingContext>
        <viewmodels:LoginViewModel />
    </ContentPage.BindingContext>

    <ScrollView>
        <VerticalStackLayout
            Padding="48,0"
            Spacing="16"
            VerticalOptions="Center">

            <material:MaterialTextField
                Keyboard="Email"
                Placeholder="Email"
                Text="{Binding Email}"
                Type="Outlined" />
            <material:MaterialTextField
                IsPassword="True"
                Placeholder="Mot de passe"
                Text="{Binding Password}"
                Type="Outlined" />
            <material:MaterialButton
                Margin="0,32"
                Command="{Binding LoginCommand}"
                HorizontalOptions="Center"
                Text="Se connecter" />
            <Label
                Margin="0,-16,0,0"
                HorizontalOptions="Center"
                IsVisible="{Binding IsLogin, Mode=OneWay, Converter={StaticResource InvertBoolToVisibilityConverter}}"
                Text="Echec d'authentification"
                TextColor="{StaticResource Error}" />

            <material:MaterialButton
                Command="{Binding RegisterCommand}"
                Text="Créer un compte"
                Type="Text" />

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
